{
  "name": "electronic-vue",
  "version": "1.0.0",
  "author": "FireOut",
  "description": "Electronic - Vue + ElementPlus",
  "main": "electron/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "electron": "chcp 65001 && vite --mode electron",
    "build": "vite build --mode electron",
    "pack": "if exist release\\win-unpacked rmdir /s /q release\\win-unpacked && vite build --mode electron && electron-builder && if exist release\\*.blockmap del /q release\\*.blockmap && if exist release\\latest.yml del /q release\\latest.yml",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.0",
    "element-plus": "^2.5.0",
    "marked": "^17.0.5",
    "pinia": "^2.1.7",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8",
    "sass": "^1.69.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.electronic.app",
    "productName": "Electronic",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [{
        "target": "nsis",
        "arch": ["x64"]
      }]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Electronic",
      "artifactName": "${productName} Setup ${version}.${ext}"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraMetadata": {
      "main": "dist-electron/index.js"
    }
  }
}
