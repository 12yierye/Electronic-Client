{
  "name": "electronic-vue",
  "version": "1.0.0",
  "author": "FireOut",
  "description": "Electronic - Vue + ElementPlus",
  "main": "electron/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "electron": "vite --mode electron",
    "build": "vite build --mode electron && electron-builder",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.0",
    "element-plus": "^2.5.0",
    "marked": "^17.0.5",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8",
    "sass": "^1.69.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.electronic.app",
    "productName": "Electronic",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraMetadata": {
      "main": "dist-electron/index.js"
    }
  }
}
